prefix=/home/harshit/Swift/build-win-x86/contrib
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: x265
Description: H.265/HEVC video encoder
Version: 4.2
Libs: -L${libdir} -lx265
Libs.private: -lstdc++ -lssp_nonshared -lssp -lgcc_s -lgcc -lgcc_s -lgcc
Cflags: -I${includedir}
