# Opus codec reference implementation pkg-config file

prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: Opus
Description: Opus IETF audio codec (@PC_BUILD@ build)
URL: https://opus-codec.org/
Version: 1.6
